[MITM]
hostname = rule.hub

[Script]
http-request ^https://rule\.hub(/)?$ script-path=http://192.168.31.92:8080/src/ui.js, timeout=10, tag=前端
http-request ^https://rule\.hub/convert script-path=http://192.168.31.92:8080/src/ui.js, timeout=30, tag=规则集转换
